@model IEnumerable<CryptonicsPropertyManagement.Models.Entities.Settlement>
@{ ViewData["Title"] = "Settlements Ledger"; var zar = new System.Globalization.CultureInfo("en-ZA"); }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Settlement Ledger</h2>
    <a asp-action="Create" class="btn btn-primary">+ Process Settlement</a>
</div>
@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["InvoiceLink"] != null)
{
    <div class="alert alert-info">
        <strong>Crypto Invoice:</strong>
        <input class="form-control mt-1" value="@TempData["InvoiceLink"]" readonly onclick="this.select();" />
    </div>
}

<table class="table table-striped table-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th><th>Lease</th><th>Gross</th><th>Maintenance</th><th>Net</th>
            <th>Fee (12%)</th><th>Owner Payout</th><th>Days</th><th>Date</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SettlementID</td>
            <td>#@item.LeaseID @(item.LeaseDisplay != null ? $"({item.LeaseDisplay})" : "")</td>
            <td>@item.GrossRent.ToString("C2", zar)</td>
            <td>@item.MaintenanceCosts.ToString("C2", zar)</td>
            <td>@item.NetAmount.ToString("C2", zar)</td>
            <td>@item.ManagementFee.ToString("C2", zar)</td>
            <td class="fw-bold">@item.OwnerPayout.ToString("C2", zar)</td>
            <td>@item.DaysOccupied</td>
            <td>@item.SettlementDate.ToString("dd MMM yyyy")</td>
        </tr>
    }
    </tbody>
</table>
