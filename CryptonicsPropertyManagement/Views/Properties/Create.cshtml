@model CryptonicsPropertyManagement.Models.Entities.Property

@{
    ViewData["Title"] = "Add New Property";
}

<div class="container mt-4">
    <h2>Add New Property</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="PropertyDescription" class="form-label">Property Description (e.g., 2 Bed Apartment)</label>
                    <input asp-for="PropertyDescription" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label asp-for="PhysicalAddress" class="form-label">Physical Address</label>
                    <input asp-for="PhysicalAddress" class="form-control" required />
                    <span asp-validation-for="PhysicalAddress" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="OwnerID" class="form-label">Property Owner</label>
                    <select asp-for="OwnerID" class="form-select" required>
                        <option value="">-- Select an Owner --</option>
                        @foreach (var owner in ViewBag.Owners)
                        {
                            <option value="@owner.OwnerID">@owner.FullName</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="MonthlyRent" class="form-label">Monthly Rent (ZAR)</label>
                    <input asp-for="MonthlyRent" type="number" step="0.01" class="form-control" required />
                </div>

                <div class="form-check mb-4">
                    <input asp-for="VacancyStatus" class="form-check-input" type="checkbox" checked />
                    <label asp-for="VacancyStatus" class="form-check-label">Property is currently Vacant</label>
                </div>

                <button type="submit" class="btn btn-success">Save Property</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>