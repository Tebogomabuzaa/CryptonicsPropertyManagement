@model CryptonicsPropertyManagement.Models.Entities.Property
@{ ViewData["Title"] = "Edit Property"; }

<h2>Edit Property #@Model.PropertyID</h2>
<hr />
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="PropertyID" />
    <input type="hidden" asp-for="PhysicalAddress" />
    <input type="hidden" asp-for="OwnerID" />

    <div class="mb-3">
        <label class="form-label">Physical Address</label>
        <input class="form-control" value="@Model.PhysicalAddress" disabled />
    </div>
    <div class="mb-3">
        <label asp-for="PropertyDescription" class="form-label"></label>
        <input asp-for="PropertyDescription" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="MonthlyRent" class="form-label">Monthly Rent (ZAR)</label>
        <input asp-for="MonthlyRent" type="number" step="0.01" class="form-control" required />
    </div>
    <div class="form-check mb-4">
        <input asp-for="VacancyStatus" class="form-check-input" type="checkbox" />
        <label asp-for="VacancyStatus" class="form-check-label">Property is Vacant</label>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
