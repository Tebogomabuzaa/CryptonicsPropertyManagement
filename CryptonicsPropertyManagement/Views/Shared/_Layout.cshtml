<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CryptoniCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">CryptoniCS</a>
                <button class="navbar-toggler navbar-toggler-right" type="button" data-toggle="collapse" data-target="#mainNav" aria-controls="mainNav" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Properties" asp-action="Index">Properties</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Owners" asp-action="Index">Owners</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Tenants" asp-action="Index">Tenants</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Managers" asp-action="Index">Managers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Leases" asp-action="Index">Leases</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Settlements" asp-action="Index">Settlements</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-toggle="dropdown">Reports</a>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" asp-controller="Reports" asp-action="CoHostPerformance">Co-Host Performance</a>
                            </div>
                        </li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Help" asp-action="Index">Help</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted py-3">
        <div class="container">
            &copy; 2026 Atlas Premier Properties — CryptoniCS Property Management System
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
