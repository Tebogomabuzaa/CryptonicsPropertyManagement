@model CryptonicsPropertyManagement.Models.Entities.Tenant
@{ ViewData["Title"] = "Edit Tenant"; }

<h2>Edit Tenant #@Model.TenantID</h2>
<hr />
<form asp-action="Edit" method="post" class="col-md-6">
    <input type="hidden" asp-for="TenantID" />
    <input type="hidden" asp-for="FirstName" />
    <input type="hidden" asp-for="LastName" />
    <input type="hidden" asp-for="PassportIDNumber" />
    <input type="hidden" asp-for="Nationality" />

    <div class="mb-3"><label class="form-label">Name</label><input class="form-control" value="@Model.FullName" disabled /></div>
    <div class="mb-3"><label asp-for="EmailAddress" class="form-label"></label><input asp-for="EmailAddress" type="email" class="form-control" required /></div>
    <div class="mb-3"><label asp-for="DeclaredMonthlyIncome" class="form-label">Declared Monthly Income (ZAR)</label><input asp-for="DeclaredMonthlyIncome" type="number" step="0.01" class="form-control" required /></div>
    <div class="mb-3">
        <label asp-for="VerificationStatus" class="form-label"></label>
        <select asp-for="VerificationStatus" class="form-select">
            <option>Pending</option>
            <option>Approved</option>
            <option>Declined - Insufficient Income</option>
            <option>Declined - Fraudulent ID</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
