@model IEnumerable<CryptonicsPropertyManagement.Models.Entities.Tenant>

@{
    ViewData["Title"] = "Tenant Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Tenant Registry & Verification</h2>
        <a asp-action="Create" class="btn btn-primary">+ Register Tenant</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-info">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Passport/ID</th>
                        <th>Declared Income</th>
                        <th>Verification Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.EmailAddress</td>
                            <td>@item.PassportIDNumber</td>
                            <td>@item.DeclaredMonthlyIncome.ToString("C2", new System.Globalization.CultureInfo("en-ZA"))</td>
                            <td>
                                @if (item.VerificationStatus == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (item.VerificationStatus == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.VerificationStatus</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                <form asp-action="RunKyc" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tenantId" value="@item.TenantID" />
                                    <input type="hidden" name="passport" value="@item.PassportIDNumber" />
                                    <input type="hidden" name="income" value="@item.DeclaredMonthlyIncome" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary"
                                            @(item.VerificationStatus == "Approved" ? "disabled" : "")>
                                        Run KYC
                                    </button>
                                </form>
                                <a asp-action="Edit" asp-route-id="@item.TenantID" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.TenantID" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>