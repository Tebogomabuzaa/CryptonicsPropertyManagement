@model CryptonicsPropertyManagement.Models.Entities.Tenant
@{ ViewData["Title"] = "Delete Tenant"; }

<h2 class="text-danger">Delete Tenant</h2>
<p>Are you sure you want to permanently remove <strong>@Model.FullName</strong>?</p>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TenantID" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
