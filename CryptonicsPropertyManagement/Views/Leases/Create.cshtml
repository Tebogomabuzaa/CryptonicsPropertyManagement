@model CryptonicsPropertyManagement.Models.Entities.LeaseAgreement
@{ ViewData["Title"] = "New Lease"; }

<h2>Create Lease Agreement</h2>
<hr />
<form asp-action="Create" method="post" class="col-md-8">
    <div class="mb-3">
        <label asp-for="PropertyID" class="form-label">Property</label>
        <select asp-for="PropertyID" class="form-select" required>
            <option value="">-- Select Property --</option>
            @foreach (var p in ViewBag.Properties)
            {
                <option value="@p.PropertyID">@p.PhysicalAddress — @p.MonthlyRent.ToString("C0", new System.Globalization.CultureInfo("en-ZA"))</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="TenantID" class="form-label">Tenant</label>
        <select asp-for="TenantID" class="form-select" required>
            <option value="">-- Select Tenant --</option>
            @foreach (var t in ViewBag.Tenants)
            {
                <option value="@t.TenantID">@t.FullName (@t.VerificationStatus)</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="ManagerID" class="form-label">Property Manager</label>
        <select asp-for="ManagerID" class="form-select" required>
            <option value="">-- Select Manager --</option>
            @foreach (var m in ViewBag.Managers)
            {
                <option value="@m.ManagerID">@m.FullName</option>
            }
        </select>
    </div>
    <div class="row mb-3">
        <div class="col"><label asp-for="StartDate" class="form-label">Lease Start</label><input asp-for="StartDate" type="date" class="form-control" required /></div>
        <div class="col"><label asp-for="EndDate" class="form-label">Lease End</label><input asp-for="EndDate" type="date" class="form-control" required /></div>
    </div>
    <div class="row mb-3">
        <div class="col"><label asp-for="RentAmount" class="form-label">Monthly Rent (ZAR)</label><input asp-for="RentAmount" type="number" step="0.01" class="form-control" required /></div>
        <div class="col">
            <label asp-for="LeaseStatus" class="form-label">Status</label>
            <select asp-for="LeaseStatus" class="form-select">
                <option>Active</option>
                <option>Expired</option>
                <option>Terminated</option>
            </select>
        </div>
    </div>
    <button type="submit" class="btn btn-success">Save Lease</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
